{
  "name": "flatstore",
  "version": "1.0.0",
  "description": "Search Flathub and download as .deb or AppImage",
  "main": "main.js",
  "author": "Legend <legend@example.com>",
  "homepage": "https://github.com/legend/flatstore",
  "scripts": {
    "start": "NODE_ENV=development electron .",
    "dev": "vite",
    "build:ui": "vite build",
    "build:app": "npm run build:ui && electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.flatstore.app",
    "productName": "FlatStore",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Legend <legend@example.com>"
    }
  }
}
